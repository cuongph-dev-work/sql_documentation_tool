{
  "name": "@cuongph.dev/dbdocgen",
  "version": "0.1.1",
  "description": "Generate database documentation from SQL schema files — Excel, Markdown, HTML, Mermaid ER diagram, and Word (A5:SQL-style layout)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuongph-dev-work/sql_documentation_tool.git"
  },
  "bugs": {
    "url": "https://github.com/cuongph-dev-work/sql_documentation_tool/issues"
  },
  "homepage": "https://github.com/cuongph-dev-work/sql_documentation_tool#readme",
  "author": "cuongph-dev-work",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "database",
    "documentation",
    "sql",
    "schema",
    "ddl",
    "excel",
    "markdown",
    "mermaid",
    "erd",
    "data-dictionary",
    "mysql",
    "postgresql",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "dbdocgen": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "npm run build && chmod +x dist/cli/index.js",
    "prepublishOnly": "npm test && npm run typecheck",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "cosmiconfig": "^9.0.2",
    "docx": "^9.7.1",
    "elkjs": "^0.11.1",
    "exceljs": "^4.4.0",
    "node-sql-parser": "^5.4.0",
    "sharp": "^0.35.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.5",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
